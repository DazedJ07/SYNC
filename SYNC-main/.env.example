# Copy to `.env` in this folder. Vite exposes only variables prefixed with VITE_.

# Organization passphrase required when an admin creates an account (Sign up → Admin).
# Must match exactly what admins type. If unset, the app defaults to 2026.
# If wrong codes are accepted, check you did not set this to something else (e.g. 2025).
VITE_ORG_SECRET=2026

# Public site URL for Google OAuth redirect + links in Supabase OTP emails (emailRedirectTo).
# Must appear in Supabase → Authentication → URL Configuration → Redirect URLs (and usually as Site URL).
# On Vercel: set Production to your real deploy URL, e.g. https://your-app.vercel.app
# Never set Production VITE_SITE_URL to http://localhost:3000 or users will be sent to localhost after login.
# Leave unset to use the current browser origin (fine for local dev).
# VITE_SITE_URL=https://your-app.vercel.app

# Supabase: set Site URL to the same production URL. If it stays localhost, magic links in email open localhost.
# Google sign-in: Authentication → Providers → Google. Redirect URLs must include your production URL and Supabase callback.
