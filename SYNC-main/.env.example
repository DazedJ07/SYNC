# Copy to `.env` in this folder. Vite exposes only variables prefixed with VITE_.

# Organization passphrase required when an admin creates an account (Sign up → Admin).
# Must match exactly what admins type. If unset, the app defaults to 2026.
# If wrong codes are accepted, check you did not set this to something else (e.g. 2025).
VITE_ORG_SECRET=2026

# Public site URL used as Google OAuth redirect (must match Supabase Auth → URL Configuration).
# Example: https://yourname.github.io/your-repo/ or https://app.example.com
# Leave unset locally to use the current browser origin + path.
# VITE_SITE_URL=https://example.com

# Google sign-in: Supabase Dashboard → Authentication → Providers → Google (Client ID + Secret).
# Add this same VITE_SITE_URL (or localhost) under Redirect URLs if OAuth returns to the wrong place.
